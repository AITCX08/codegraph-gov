# Root directory the codegraph indexer scanned.
CODEGRAPH_WORKSPACE_ROOT=/path/to/your/workspace
# Read-only codegraph SQLite index (default: $CODEGRAPH_WORKSPACE_ROOT/.codegraph/codegraph.db).
CODEGRAPH_DB_PATH=/path/to/your/workspace/.codegraph/codegraph.db
# Comma-separated top-level dirs to treat as vendored/third-party (optional).
CODEGRAPH_BLACKLIST_ROOTS=
# Where gen-docs writes the rendered markdown catalog (optional).
CODEGRAPH_DOCS_MARKDOWN_OUT=docs/interface_catalog.md

# Optional: use the OpenAI-compatible API embedder instead of the local ONNX one.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: perception-scan (poll a Gitea host for newly added DB schema fields).
GITEA_HOST=git.example.com
GITEA_OWNER=your-org
GITEA_TOKEN=
